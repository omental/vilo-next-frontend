# Backend production env (example)
# Copy to backend/.env on server and set real secrets.

DATABASE_URL=postgresql+asyncpg://vilo_user:CHANGE_ME@127.0.0.1:5432/vilo
JWT_SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120

APP_BASE_URL=https://muba.me
PUBLIC_BACKEND_URL=https://api.muba.me
ONLYOFFICE_DOCUMENT_SERVER_URL=https://docs.muba.me
ONLYOFFICE_JWT_SECRET=CHANGE_ME_ONLYOFFICE_SHARED_SECRET
ONLYOFFICE_FILE_TOKEN_EXPIRES_MINUTES=15

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@muba.me
